# ── Skillbrew.AI v2 Configuration ───────────────────────────────
# Copy to .env and fill in values. Never commit .env.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

CAMERA_INDEX=0
MAX_TRAIN_IMAGES=8000

# Flask API server
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false

# Model paths
STRESS_MODEL_PATH=models/stress_ai.pkl
TRAITS_MODEL_PATH=models/traits_ai.pkl

# Logging
LOG_PATH=logs/session.csv
FER_DIR=data/fer2013
